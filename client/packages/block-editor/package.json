{
  "name": "@vance/block-editor",
  "version": "1.0.0",
  "private": true,
  "description": "Shared Notion-style block editor (Tiptap-based) + Markdown-Superset codec for Vance. Consumed by the canvas addon's mount wrapper and any other addon that wants to embed the editor (e.g. workspace master-detail view). Single source of truth for editor schema, NodeViews and Markdown round-trip.",
  "license": "SEE LICENSE IN ../../../LICENSE.txt",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./src/index.ts"
    },
    "./CanvasEditor.vue": {
      "types": "./dist/CanvasEditor.vue.d.ts",
      "import": "./src/CanvasEditor.vue"
    }
  },
  "files": ["src"],
  "scripts": {
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@tiptap/core": "^2.10.4",
    "@tiptap/pm": "^2.10.4",
    "@tiptap/starter-kit": "^2.10.4",
    "@tiptap/vue-3": "^2.10.4",
    "@tiptap/extension-task-list": "^2.10.4",
    "@tiptap/extension-task-item": "^2.10.4",
    "@tiptap/extension-image": "^2.10.4",
    "@tiptap/extension-table": "^2.10.4",
    "@tiptap/extension-table-row": "^2.10.4",
    "@tiptap/extension-table-cell": "^2.10.4",
    "@tiptap/extension-table-header": "^2.10.4",
    "js-yaml": "^4.1.0"
  },
  "peerDependencies": {
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "vue": "^3.5.13"
  }
}
