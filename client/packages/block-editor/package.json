{
  "name": "@vance/block-editor",
  "version": "1.0.0",
  "private": true,
  "description": "Shared Notion-style block editor (Tiptap-based) + Markdown-Superset codec for Vance. Consumed by the workspace addon (workpage editor + master-detail view) and any other host that wants to embed the editor. Single source of truth for the workpage block schema, NodeViews and Markdown round-trip.",
  "license": "SEE LICENSE IN ../../../LICENSE.txt",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./src/index.ts"
    },
    "./WorkPageEditor.vue": {
      "types": "./dist/WorkPageEditor.vue.d.ts",
      "import": "./src/WorkPageEditor.vue"
    },
    "./blockRegistry": {
      "types": "./dist/blockRegistry.d.ts",
      "import": "./src/blockRegistry.ts"
    }
  },
  "files": ["src"],
  "scripts": {
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@tiptap/core": "^2.10.4",
    "@tiptap/pm": "^2.10.4",
    "@tiptap/starter-kit": "^2.10.4",
    "@tiptap/vue-3": "^2.10.4",
    "@tiptap/extension-task-list": "^2.10.4",
    "@tiptap/extension-task-item": "^2.10.4",
    "@tiptap/extension-image": "^2.10.4",
    "@tiptap/extension-table": "^2.10.4",
    "@tiptap/extension-table-row": "^2.10.4",
    "@tiptap/extension-table-cell": "^2.10.4",
    "@tiptap/extension-table-header": "^2.10.4",
    "@tiptap/extension-link": "^2.10.4",
    "@tiptap/extension-bubble-menu": "^2.10.4",
    "@tiptap/extension-placeholder": "^2.10.4",
    "@tiptap/suggestion": "^2.10.4",
    "@tiptap/extension-code-block-lowlight": "^2.10.4",
    "tiptap-extension-global-drag-handle": "^0.1.16",
    "tippy.js": "^6.3.7",
    "js-yaml": "^4.1.0",
    "lowlight": "^3.1.0",
    "highlight.js": "^11.10.0"
  },
  "peerDependencies": {
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "vue": "^3.5.13"
  }
}
