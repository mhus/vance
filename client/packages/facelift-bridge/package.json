{
  "name": "@vance/facelift-bridge",
  "version": "0.1.0",
  "private": true,
  "description": "Vance Facelift — thin Capacitor wrapper around the deployed Vance web UI. Native account picker + brain URL switching; the live website handles auth and editors itself.",
  "license": "SEE LICENSE IN ../../LICENSE.txt",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "assets:regenerate-png": "qlmanage -t -s 1024 -o assets assets/icon-source.svg && qlmanage -t -s 2732 -o assets assets/splash-source.svg && mv assets/icon-source.svg.png assets/icon-only.png && mv assets/splash-source.svg.png assets/splash.png && cp assets/splash.png assets/splash-dark.png",
    "assets:generate": "capacitor-assets generate --ios",
    "cap:sync": "cap sync",
    "cap:add:ios": "bash scripts/cap-add-ios.sh",
    "cap:open:ios": "cap open ios",
    "cap:run:ios": "cap run ios --livereload --external",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@capacitor/camera": "^6.1.0",
    "@capacitor/core": "^6.2.0",
    "@capacitor/filesystem": "^6.0.3",
    "@capacitor/ios": "^6.2.0",
    "@capacitor/preferences": "^6.0.3",
    "@capacitor/share": "^6.0.3",
    "@capacitor/splash-screen": "^6.0.3",
    "@capacitor/status-bar": "^6.0.2",
    "@capawesome/capacitor-file-picker": "^6.2.0",
    "@vance/facelift-account-webview": "workspace:*",
    "pinia": "^2.2.4",
    "vue": "^3.5.13",
    "vue-router": "^4.4.5"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^6.2.0",
    "@vitejs/plugin-vue": "^5.2.1",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "sharp": "^0.35.1",
    "tailwindcss": "^3.4.17",
    "vite": "^5.4.11",
    "vue-tsc": "^2.1.10"
  }
}
