# Vance Web-UI build-time configuration. Vite reads VITE_* envs and
# inlines them into the bundle. To override the defaults, copy this file
# to `.env` (or `.env.local` for non-checked-in overrides) in the same
# directory and rebuild (`pnpm --filter @vance/vance-face build`).
#
# Values are CSS colour strings — hex, rgb(), oklch(), CSS custom
# properties (`var(--my-token)`), anything the browser accepts. Empty
# values fall back to the built-in DaisyUI defaults.
#
# This is the web equivalent of the foot client's
# `vance.ui.colors.*` (application.yaml). The format differs
# intentionally — JLine style expressions don't translate to CSS.

# ──────────────── Bubble colours ────────────────

# Worker (sub-process chat echo). Foreground only — the worker bubble
# is a transparent one-liner, no background.
VITE_VANCE_COLOR_WORKER=

# User bubble (your messages).
VITE_VANCE_COLOR_USER_FG=
VITE_VANCE_COLOR_USER_BG=

# Assistant bubble (chat-process replies).
VITE_VANCE_COLOR_ASSISTANT_FG=
VITE_VANCE_COLOR_ASSISTANT_BG=

# System bubble (system notes interleaved into the conversation).
VITE_VANCE_COLOR_SYSTEM_FG=
VITE_VANCE_COLOR_SYSTEM_BG=

# ──────────────── Behaviour ────────────────

# Worker chat-echo truncation cap. 0 disables truncation. Mirrors the
# foot client's `vance.ui.line-max-chars`.
VITE_VANCE_LINE_MAX_CHARS=140
