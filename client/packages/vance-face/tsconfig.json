{
  "extends": "../../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "outDir": "./dist-types",
    "rootDir": ".",
    "jsx": "preserve",
    "types": ["vite/client", "node"],
    "paths": {
      "@/*": ["./src/*"],
      "@components/*": ["./src/components/*"],
      "@composables/*": ["./src/composables/*"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.vue", "vite.config.ts", "env.d.ts"],
  "exclude": ["src/**/*.test.ts"],
  "references": [
    { "path": "../components" },
    { "path": "../generated" },
    { "path": "../kind-registry" },
    { "path": "../runner-registry" },
    { "path": "../shared" },
    { "path": "../../../server/vance-addon-brain-slideshow/client" }
  ]
}
