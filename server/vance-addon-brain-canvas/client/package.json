{
  "name": "@vance-addon/canvas",
  "version": "1.0.0",
  "private": true,
  "description": "Client surface of the Canvas Brain addon. Registers the spatial kind: canvas (read-only board) and the application:canvasbook app kind (editable), rendered with VueFlow.",
  "license": "SEE LICENSE IN ../../../../client/LICENSE.txt",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./src/index.ts"
    }
  },
  "files": ["src", "dist"],
  "scripts": {
    "build": "vue-tsc -b && vite build",
    "dev": "vite",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@vance/components": "workspace:*",
    "@vance/kind-registry": "workspace:*",
    "@vance/shared": "workspace:*",
    "@vue-flow/core": "^1.48.2",
    "@vue-flow/node-resizer": "^1.4.0",
    "@vue-flow/node-toolbar": "^1.1.0"
  },
  "peerDependencies": {
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "@module-federation/vite": "^1.4.0",
    "@vitejs/plugin-vue": "^5.2.1",
    "vite": "^5.4.11",
    "vue": "^3.5.13",
    "vue-tsc": "^2.1.10"
  }
}
