{
  "name": "@vance-addon/common-desktop",
  "version": "1.0.0",
  "private": true,
  "description": "Client surface of the Common Desktop Brain addon — TypeScript DTOs (generated from Java), REST helper and the Vue launcher/status board. Federation remote consumed by vance-face.",
  "license": "SEE LICENSE IN ../../../../client/LICENSE.txt",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./src/index.ts"
    },
    "./DesktopBoard.vue": {
      "types": "./dist/DesktopBoard.vue.d.ts",
      "import": "./src/DesktopBoard.vue"
    }
  },
  "files": ["src", "dist"],
  "scripts": {
    "build": "vue-tsc -b && vite build",
    "dev": "vite",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@vance/components": "workspace:*",
    "@vance/kind-registry": "workspace:*",
    "@vance/shared": "workspace:*"
  },
  "peerDependencies": {
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "@module-federation/vite": "^1.4.0",
    "@vitejs/plugin-vue": "^5.2.1",
    "vite": "^5.4.11",
    "vue": "^3.5.13",
    "vue-tsc": "^2.1.10"
  }
}
