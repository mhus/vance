{
  "name": "@vance-addon/kanban",
  "version": "1.0.0",
  "private": true,
  "description": "Client surface of the Kanban Brain addon — TypeScript DTOs (generated from Java), REST helpers and the Vue board editor. Federation remote consumed by vance-face.",
  "license": "SEE LICENSE IN ../../../../client/LICENSE.txt",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./src/index.ts"
    },
    "./KanbanBoard.vue": {
      "types": "./dist/KanbanBoard.vue.d.ts",
      "import": "./src/KanbanBoard.vue"
    }
  },
  "files": ["src", "dist"],
  "scripts": {
    "build": "vue-tsc -b && vite build",
    "dev": "vite",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@vance/block-editor": "workspace:*",
    "@vance/components": "workspace:*",
    "@vance/kind-registry": "workspace:*",
    "@vance/shared": "workspace:*",
    "vue-draggable-plus": "^0.6.1"
  },
  "peerDependencies": {
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "@module-federation/vite": "^1.4.0",
    "@tiptap/core": "^2.10.4",
    "@tiptap/pm": "^2.10.4",
    "@tiptap/vue-3": "^2.10.4",
    "@vitejs/plugin-vue": "^5.2.1",
    "vite": "^5.4.11",
    "vue": "^3.5.13",
    "vue-tsc": "^2.1.10"
  }
}
