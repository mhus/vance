{
  "name": "@vance-addon/wiki",
  "version": "1.0.0",
  "private": true,
  "description": "Client surface of the Wiki Brain addon. Registers the application:wiki kind and reuses @vance/block-editor's WorkPageEditor with wikilink resolution injected.",
  "license": "SEE LICENSE IN ../../../../client/LICENSE.txt",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./src/index.ts"
    }
  },
  "files": [
    "src",
    "dist"
  ],
  "scripts": {
    "build": "vue-tsc -b && vite build",
    "dev": "vite",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@vance/block-editor": "workspace:*",
    "@vance/components": "workspace:*",
    "@vance/generated": "workspace:*",
    "@vance/kind-registry": "workspace:*",
    "@vance/shared": "workspace:*"
  },
  "peerDependencies": {
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "@module-federation/vite": "^1.4.0",
    "@tiptap/core": "^2.10.4",
    "@tiptap/vue-3": "^2.10.4",
    "@vitejs/plugin-vue": "^5.2.1",
    "vite": "^5.4.11",
    "vitest": "^2.1.9",
    "vue": "^3.5.13",
    "vue-tsc": "^2.1.10"
  }
}
